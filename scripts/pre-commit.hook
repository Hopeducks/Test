#!/usr/bin/env bash
# pre-commit: 시크릿 및 민감 파일 커밋 차단 훅
# 이 파일은 `git commit` 실행 시 자동으로 호출됩니다.

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

ERRORS=0

echo "🔍 [pre-commit] 시크릿 스캔 시작..."

# ─── 1. 민감 파일명 차단 ───────────────────────────────────────────
BLOCKED_FILES=(
  "\.env$"
  "\.env\.local$"
  "\.env\.development$"
  "\.env\.production$"
  "\.env\.staging$"
  "secrets\.json$"
  "secrets\..+\.json$"
  "\.pem$"
  "\.key$"
  "\.p12$"
  "\.pfx$"
  "serviceAccountKey\.json$"
)

STAGED_FILES=$(git diff --cached --name-only)

for pattern in "${BLOCKED_FILES[@]}"; do
  while IFS= read -r file; do
    if echo "$file" | grep -qE "$pattern"; then
      echo -e "${RED}❌ 차단됨: 민감 파일은 커밋할 수 없습니다 → $file${NC}"
      ERRORS=$((ERRORS + 1))
    fi
  done <<< "$STAGED_FILES"
done

# ─── 2. 시크릿 패턴 스캔 ──────────────────────────────────────────
# 검사할 staged 파일 목록 (바이너리 및 lock 파일 제외)
SCANNABLE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '\.(png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|mp3|wav|zip|tar|gz|lock)$' | grep -v 'package-lock\.json')

if [ -z "$SCANNABLE_FILES" ]; then
  echo -e "${GREEN}✅ 스캔할 텍스트 파일 없음${NC}"
  exit 0
fi

# 패턴 정의: [설명] [정규식]
declare -A PATTERNS
PATTERNS["Supabase JWT (anon/service key)"]='^[^#]*eyJ[A-Za-z0-9_-]{50,}\.[A-Za-z0-9_-]{50,}\.[A-Za-z0-9_-]{10,}'
PATTERNS["Supabase Project URL (하드코딩)"]='^[^#]*[a-z]{10,30}\.supabase\.co'
PATTERNS["OpenAI API Key"]='^[^#]*sk-[A-Za-z0-9]{20,}'
PATTERNS["Generic Secret Assignment"]='(SECRET|API_KEY|PRIVATE_KEY|PASSWORD|TOKEN)\s*=\s*["\x27][^"\x27$\{]{8,}'

while IFS= read -r file; do
  [ -f "$file" ] || continue

  # git show로 staged 내용 검사 (워킹트리 파일이 아닌 staged 내용 기준)
  CONTENT=$(git show ":$file" 2>/dev/null)

  for desc in "${!PATTERNS[@]}"; do
    regex="${PATTERNS[$desc]}"
    MATCHES=$(echo "$CONTENT" | grep -nE "$regex" | grep -v '\.example' | grep -v 'process\.env' | grep -v '@[a-z_]+$')
    if [ -n "$MATCHES" ]; then
      echo -e "${RED}❌ 시크릿 감지: [$desc]${NC}"
      echo -e "   파일: ${YELLOW}$file${NC}"
      echo "$MATCHES" | head -3 | while read -r line; do
        echo -e "   → ${YELLOW}$line${NC}"
      done
      ERRORS=$((ERRORS + 1))
    fi
  done
done <<< "$SCANNABLE_FILES"

# ─── 3. NEXT_PUBLIC_ 키에 실제 값 하드코딩 감지 ───────────────────
# process.env.NEXT_PUBLIC_... 참조는 허용, 문자열 직접 할당은 차단
while IFS= read -r file; do
  [ -f "$file" ] || continue
  CONTENT=$(git show ":$file" 2>/dev/null)
  MATCHES=$(echo "$CONTENT" | grep -nE 'NEXT_PUBLIC_[A-Z_]+\s*=\s*["\x27][^"\x27$\{]{4,}' | grep -v '\.example' | grep -v '#')
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}❌ 환경 변수 하드코딩 감지:${NC}"
    echo -e "   파일: ${YELLOW}$file${NC}"
    echo "$MATCHES" | head -3 | while read -r line; do
      echo -e "   → ${YELLOW}$line${NC}"
    done
    ERRORS=$((ERRORS + 1))
  fi
done <<< "$SCANNABLE_FILES"

# ─── 결과 ──────────────────────────────────────────────────────────
if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo -e "${RED}🚨 커밋 차단: 시크릿 또는 민감 파일이 감지되었습니다.${NC}"
  echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
  echo ""
  echo -e "  해결 방법:"
  echo -e "  1. 민감 정보를 ${YELLOW}.env.local${NC} 파일로 이동하세요."
  echo -e "  2. 코드에서는 ${GREEN}process.env.VARIABLE_NAME${NC} 형태로 참조하세요."
  echo -e "  3. ${YELLOW}.env.local${NC} 은 .gitignore에 포함되어 있어 추적되지 않습니다."
  echo -e "  4. 프로덕션 배포는 Vercel/Supabase 대시보드에서 환경 변수를 직접 설정하세요."
  echo ""
  exit 1
fi

echo -e "${GREEN}✅ [pre-commit] 시크릿 스캔 통과. 커밋을 진행합니다.${NC}"
exit 0
